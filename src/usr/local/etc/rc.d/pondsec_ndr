#!/bin/sh

# PROVIDE: pondsec_ndr
# REQUIRE: LOGIN
# KEYWORD: shutdown

. /etc/rc.subr

name="pondsec_ndr"
rcvar="pondsec_ndr_enable"
command="/usr/sbin/daemon"
pidfile="/var/run/pondsec-ndr/pondsec-ndr.pid"
procname="/usr/local/bin/python3"
required_dirs="/usr/local/etc/pondsec-ndr /var/db/pondsec-ndr /var/log/pondsec-ndr /var/run/pondsec-ndr"
start_precmd="${name}_prestart"

load_rc_config "$name"
: ${pondsec_ndr_enable:="NO"}
: ${pondsec_ndr_user:="pondsecndr"}
command_args="-f -H -p ${pidfile} -o /var/log/pondsec-ndr/pondsec-ndr-service.log /usr/local/sbin/pondsec-ndr"

pondsec_ndr_prestart()
{
    if [ -d /var/log/suricata ]; then
        chmod 750 /var/log/suricata 2>/dev/null || true
        setfacl -m u:${pondsec_ndr_user}:xaRcs::allow /var/log/suricata 2>/dev/null || true
        if [ -f /var/log/suricata/eve.json ]; then
            chown root:${pondsec_ndr_user} /var/log/suricata/eve.json 2>/dev/null || true
            chmod 640 /var/log/suricata/eve.json 2>/dev/null || true
            setfacl -m u:${pondsec_ndr_user}:raRcs::allow /var/log/suricata/eve.json 2>/dev/null || true
        fi
    fi
    if [ -f /etc/newsyslog.conf.d/suricata ]; then
        sed -i "" -E "s#^(/var/log/suricata/eve\\.json[[:space:]]+)root:wheel([[:space:]]+640[[:space:]])#\\1root:${pondsec_ndr_user}\\2#" /etc/newsyslog.conf.d/suricata 2>/dev/null || true
    fi
    if [ -d /var/log/filter ]; then
        setfacl -m u:${pondsec_ndr_user}:rxaRcs:fd:allow /var/log/filter 2>/dev/null || true
        if [ -e /var/log/filter/latest.log ]; then
            filter_target="$(readlink /var/log/filter/latest.log 2>/dev/null || true)"
            if [ -n "${filter_target}" ] && [ "${filter_target#/}" = "${filter_target}" ]; then
                filter_target="/var/log/filter/${filter_target}"
            fi
            if [ -z "${filter_target}" ]; then
                filter_target="/var/log/filter/latest.log"
            fi
            setfacl -m u:${pondsec_ndr_user}:raRcs::allow "${filter_target}" 2>/dev/null || true
        fi
    fi
    if [ -d /var/log/dnsmasq ]; then
        setfacl -m u:${pondsec_ndr_user}:rxaRcs::allow /var/log/dnsmasq 2>/dev/null || true
        setfacl -m u:${pondsec_ndr_user}:rxaRcs:fd:allow /var/log/dnsmasq 2>/dev/null || true
        find /var/log/dnsmasq -maxdepth 1 -type f -name "*.log" -exec setfacl -m u:${pondsec_ndr_user}:raRcs::allow {} \; 2>/dev/null || true
        if [ -e /var/log/dnsmasq/latest.log ]; then
            dnsmasq_target="$(readlink /var/log/dnsmasq/latest.log 2>/dev/null || true)"
            if [ -n "${dnsmasq_target}" ] && [ "${dnsmasq_target#/}" = "${dnsmasq_target}" ]; then
                dnsmasq_target="/var/log/dnsmasq/${dnsmasq_target}"
            fi
            if [ -n "${dnsmasq_target}" ]; then
                setfacl -m u:${pondsec_ndr_user}:raRcs::allow "${dnsmasq_target}" 2>/dev/null || true
            fi
        fi
    fi
}

run_rc_command "$1"
