<acl>
    <pondsec-ndr-dashboard>
        <name>WebCfg - PondSec NDR: Dashboard</name>
        <description>View PondSec NDR dashboard data</description>
        <patterns>
            <pattern>ui/pondsecndr/dashboard</pattern>
            <pattern>api/pondsecndr/dashboard/*</pattern>
            <pattern>api/pondsecndr/service/status</pattern>
        </patterns>
    </pondsec-ndr-dashboard>
    <pondsec-ndr-view-incidents>
        <name>WebCfg - PondSec NDR: View incidents</name>
        <description>View PondSec NDR incidents</description>
        <patterns>
            <pattern>ui/pondsecndr/incidents</pattern>
            <pattern>api/pondsecndr/incidents/list</pattern>
            <pattern>api/pondsecndr/incidents/get/*</pattern>
        </patterns>
    </pondsec-ndr-view-incidents>
    <pondsec-ndr-manage-incidents>
        <name>WebCfg - PondSec NDR: Manage incidents</name>
        <description>Close, reopen, and annotate PondSec NDR incidents</description>
        <patterns>
            <pattern>api/pondsecndr/incidents/close/*</pattern>
            <pattern>api/pondsecndr/incidents/reopen/*</pattern>
        </patterns>
    </pondsec-ndr-manage-incidents>
    <pondsec-ndr-view-hosts>
        <name>WebCfg - PondSec NDR: View hosts</name>
        <description>View PondSec NDR hosts</description>
        <patterns>
            <pattern>ui/pondsecndr/hosts</pattern>
            <pattern>api/pondsecndr/hosts/*</pattern>
        </patterns>
    </pondsec-ndr-view-hosts>
    <pondsec-ndr-view-detections>
        <name>WebCfg - PondSec NDR: View detections</name>
        <description>View PondSec NDR detections</description>
        <patterns>
            <pattern>ui/pondsecndr/detections</pattern>
            <pattern>api/pondsecndr/detections/*</pattern>
        </patterns>
    </pondsec-ndr-view-detections>
    <pondsec-ndr-manage-policies>
        <name>WebCfg - PondSec NDR: Manage policies</name>
        <description>Manage PondSec NDR policies</description>
        <patterns>
            <pattern>ui/pondsecndr/policies</pattern>
            <pattern>api/pondsecndr/policies/*</pattern>
        </patterns>
    </pondsec-ndr-manage-policies>
    <pondsec-ndr-manage-models>
        <name>WebCfg - PondSec NDR: Manage models</name>
        <description>Manage PondSec NDR models</description>
        <patterns>
            <pattern>ui/pondsecndr/models</pattern>
            <pattern>api/pondsecndr/models/*</pattern>
        </patterns>
    </pondsec-ndr-manage-models>
    <pondsec-ndr-manage-blocklist>
        <name>WebCfg - PondSec NDR: Manage blocklist</name>
        <description>Manage PondSec NDR blocklist entries</description>
        <patterns>
            <pattern>ui/pondsecndr/blocklist</pattern>
            <pattern>api/pondsecndr/blocklist/*</pattern>
        </patterns>
    </pondsec-ndr-manage-blocklist>
    <pondsec-ndr-manage-allowlist>
        <name>WebCfg - PondSec NDR: Manage allowlist</name>
        <description>Manage PondSec NDR allowlist entries</description>
        <patterns>
            <pattern>ui/pondsecndr/allowlist</pattern>
            <pattern>api/pondsecndr/allowlist/*</pattern>
        </patterns>
    </pondsec-ndr-manage-allowlist>
    <pondsec-ndr-manage-service>
        <name>WebCfg - PondSec NDR: Manage service</name>
        <description>Start, stop, restart, and inspect the PondSec NDR service</description>
        <patterns>
            <pattern>ui/pondsecndr/service</pattern>
            <pattern>api/pondsecndr/service/*</pattern>
        </patterns>
    </pondsec-ndr-manage-service>
    <pondsec-ndr-view-logs>
        <name>WebCfg - PondSec NDR: View logs</name>
        <description>View PondSec NDR logs</description>
        <patterns>
            <pattern>ui/pondsecndr/logs</pattern>
            <pattern>api/pondsecndr/logs/*</pattern>
        </patterns>
    </pondsec-ndr-view-logs>
    <pondsec-ndr-run-diagnostics>
        <name>WebCfg - PondSec NDR: Diagnostics</name>
        <description>Run PondSec NDR diagnostics</description>
        <patterns>
            <pattern>ui/pondsecndr/diagnostics</pattern>
            <pattern>api/pondsecndr/diagnostics/*</pattern>
        </patterns>
    </pondsec-ndr-run-diagnostics>
    <pondsec-ndr-manage-settings>
        <name>WebCfg - PondSec NDR: Manage settings</name>
        <description>Manage PondSec NDR settings</description>
        <patterns>
            <pattern>ui/pondsecndr/settings</pattern>
            <pattern>api/pondsecndr/settings/*</pattern>
        </patterns>
    </pondsec-ndr-manage-settings>
</acl>
